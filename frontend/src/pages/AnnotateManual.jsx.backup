import React, { useState, useEffect, useRef } from 'react';
import { useParams, useSearchParams, useNavigate } from 'react-router-dom';
import { Stage, Layer, Image as KonvaImage, Rect, Transformer } from 'react-konva';
import { 
  Layout, 
  Button, 
  List, 
  Input, 
  Tabs, 
  Card, 
  Space, 
  Tooltip, 
  message, 
  Modal, 
  Select, 
  Typography,
  Divider,
  Tag,
  Slider
} from 'antd';
import {
  ZoomInOutlined,
  ZoomOutOutlined,
  SelectOutlined,
  BorderOutlined,
  UndoOutlined,
  RedoOutlined,
  DeleteOutlined,
  ReloadOutlined,
  SaveOutlined,
  PlusOutlined,
  ArrowLeftOutlined,
  EyeOutlined,
  EyeInvisibleOutlined
} from '@ant-design/icons';
import axios from 'axios';

const { Sider, Content } = Layout;
const { TextArea } = Input;
const { Title, Text } = Typography;

const AnnotateManual = () => {
  const { datasetId } = useParams();
  const [searchParams] = useSearchParams();
  const imageId = searchParams.get('imageId');
  const navigate = useNavigate();

  // Canvas and image state
  const [image, setImage] = useState(null);
  const [imageData, setImageData] = useState(null);
  const [stageScale, setStageScale] = useState(1);
  const [stagePosition, setStagePosition] = useState({ x: 0, y: 0 });
  const stageRef = useRef();
  const transformerRef = useRef();

  // Annotation state
  const [annotations, setAnnotations] = useState([]);
  const [selectedAnnotationId, setSelectedAnnotationId] = useState(null);
  const [isDrawing, setIsDrawing] = useState(false);
  const [currentTool, setCurrentTool] = useState('select'); // 'select' or 'draw'
  const [newAnnotation, setNewAnnotation] = useState(null);

  // Classes state
  const [classes, setClasses] = useState([
    { id: 1, name: 'Good', color: '#52c41a' },
    { id: 2, name: 'Broken', color: '#ff4d4f' },
    { id: 3, name: 'Holes', color: '#faad14' }
  ]);
  const [selectedClassId, setSelectedClassId] = useState(1);
  const [newClassName, setNewClassName] = useState('');
  const [showAddClass, setShowAddClass] = useState(false);

  // History state
  const [history, setHistory] = useState([]);
  const [historyIndex, setHistoryIndex] = useState(-1);

  // Comments state
  const [comments, setComments] = useState([]);
  const [newComment, setNewComment] = useState('');

  // UI state
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);

  // Load image and annotations
  useEffect(() => {
    if (imageId && datasetId) {
      loadImageAndAnnotations();
    }
  }, [imageId, datasetId]);

  const loadImageAndAnnotations = async () => {
    try {
      setLoading(true);
      
      // Load image info
      const imageResponse = await axios.get(`/api/v1/images/${imageId}`);
      const imageData = imageResponse.data;
      setImage(imageData);
      
      // Load image object
      const img = new window.Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        setImageObj(img);
        setLoading(false);
      };
      img.src = imageData.file_path;
      
      // Load existing annotations
      try {
        const annotationsResponse = await axios.get(`/api/v1/images/${imageId}/annotations`);
        const existingAnnotations = annotationsResponse.data.map((ann, index) => ({
          id: ann.id || `annotation-${index}`,
          class: ann.class_name,
          x: ann.x,
          y: ann.y,
          width: ann.width,
          height: ann.height,
          color: getClassColor(ann.class_name)
        }));
        setAnnotations(existingAnnotations);
        saveToHistory(existingAnnotations);
      } catch (error) {
        console.log('No existing annotations found');
        setAnnotations([]);
        saveToHistory([]);
      }
      
    } catch (error) {
      console.error('Error loading image:', error);
      message.error('Failed to load image');
    }
  };

  const getClassColor = (className) => {
    const colors = ['#ff4d4f', '#52c41a', '#1890ff', '#fa8c16', '#722ed1', '#eb2f96'];
    const index = classes.indexOf(className);
    return colors[index % colors.length];
  };

  const saveToHistory = (newAnnotations) => {
    const newHistory = history.slice(0, historyStep + 1);
    newHistory.push([...newAnnotations]);
    setHistory(newHistory);
    setHistoryStep(newHistory.length - 1);
  };

  const undo = () => {
    if (historyStep > 0) {
      setHistoryStep(historyStep - 1);
      setAnnotations([...history[historyStep - 1]]);
    }
  };

  const redo = () => {
    if (historyStep < history.length - 1) {
      setHistoryStep(historyStep + 1);
      setAnnotations([...history[historyStep + 1]]);
    }
  };

  const handleMouseDown = (e) => {
    if (tool !== 'draw') return;
    
    const stage = e.target.getStage();
    const point = stage.getPointerPosition();
    const newAnnotation = {
      id: `annotation-${Date.now()}`,
      class: selectedClass,
      x: point.x / zoom - stagePos.x / zoom,
      y: point.y / zoom - stagePos.y / zoom,
      width: 0,
      height: 0,
      color: getClassColor(selectedClass)
    };
    
    setAnnotations([...annotations, newAnnotation]);
    setIsDrawing(true);
  };

  const handleMouseMove = (e) => {
    if (!isDrawing || tool !== 'draw') return;
    
    const stage = e.target.getStage();
    const point = stage.getPointerPosition();
    const newAnnotations = [...annotations];
    const lastAnnotation = newAnnotations[newAnnotations.length - 1];
    
    lastAnnotation.width = (point.x / zoom - stagePos.x / zoom) - lastAnnotation.x;
    lastAnnotation.height = (point.y / zoom - stagePos.y / zoom) - lastAnnotation.y;
    
    setAnnotations(newAnnotations);
  };

  const handleMouseUp = () => {
    if (isDrawing) {
      setIsDrawing(false);
      saveToHistory(annotations);
    }
  };

  const handleAnnotationClick = (annotation) => {
    if (tool === 'select') {
      setSelectedAnnotation(annotation);
      const transformer = transformerRef.current;
      const stage = stageRef.current;
      const rect = stage.findOne(`#${annotation.id}`);
      
      if (rect && transformer) {
        transformer.nodes([rect]);
        transformer.getLayer().batchDraw();
      }
    }
  };

  const handleTransformEnd = (e) => {
    const rect = e.target;
    const scaleX = rect.scaleX();
    const scaleY = rect.scaleY();
    
    const newAnnotations = annotations.map(ann => {
      if (ann.id === selectedAnnotation?.id) {
        return {
          ...ann,
          x: rect.x(),
          y: rect.y(),
          width: rect.width() * scaleX,
          height: rect.height() * scaleY
        };
      }
      return ann;
    });
    
    rect.scaleX(1);
    rect.scaleY(1);
    
    setAnnotations(newAnnotations);
    saveToHistory(newAnnotations);
  };

  const deleteSelectedAnnotation = () => {
    if (selectedAnnotation) {
      const newAnnotations = annotations.filter(ann => ann.id !== selectedAnnotation.id);
      setAnnotations(newAnnotations);
      setSelectedAnnotation(null);
      saveToHistory(newAnnotations);
      
      const transformer = transformerRef.current;
      if (transformer) {
        transformer.nodes([]);
        transformer.getLayer().batchDraw();
      }
    }
  };

  const resetAnnotations = () => {
    Modal.confirm({
      title: 'Reset All Annotations',
      content: 'Are you sure you want to delete all annotations? This action cannot be undone.',
      onOk: () => {
        setAnnotations([]);
        setSelectedAnnotation(null);
        saveToHistory([]);
        
        const transformer = transformerRef.current;
        if (transformer) {
          transformer.nodes([]);
          transformer.getLayer().batchDraw();
        }
      }
    });
  };

  const handleZoomIn = () => {
    const newZoom = Math.min(zoom * 1.2, 5);
    setZoom(newZoom);
  };

  const handleZoomOut = () => {
    const newZoom = Math.max(zoom / 1.2, 0.1);
    setZoom(newZoom);
  };

  const handleWheel = (e) => {
    e.evt.preventDefault();
    
    const scaleBy = 1.02;
    const stage = e.target.getStage();
    const oldScale = stage.scaleX();
    const pointer = stage.getPointerPosition();
    
    const mousePointTo = {
      x: (pointer.x - stage.x()) / oldScale,
      y: (pointer.y - stage.y()) / oldScale,
    };
    
    const newScale = e.evt.deltaY > 0 ? oldScale * scaleBy : oldScale / scaleBy;
    const clampedScale = Math.max(0.1, Math.min(5, newScale));
    
    setZoom(clampedScale);
    
    const newPos = {
      x: pointer.x - mousePointTo.x * clampedScale,
      y: pointer.y - mousePointTo.y * clampedScale,
    };
    
    setStagePos(newPos);
  };

  const saveAnnotations = async () => {
    try {
      setSaving(true);
      
      const annotationData = annotations.map(ann => ({
        class_name: ann.class,
        x: Math.round(ann.x),
        y: Math.round(ann.y),
        width: Math.round(ann.width),
        height: Math.round(ann.height)
      }));
      
      await axios.post(`/api/v1/images/${imageId}/annotations`, {
        annotations: annotationData
      });
      
      message.success('Annotations saved successfully!');
    } catch (error) {
      console.error('Error saving annotations:', error);
      message.error('Failed to save annotations');
    } finally {
      setSaving(false);
    }
  };

  const addNewClass = () => {
    if (newClassName.trim() && !classes.includes(newClassName.trim())) {
      setClasses([...classes, newClassName.trim()]);
      setNewClassName('');
      setNewClassModalVisible(false);
      message.success(`Class "${newClassName.trim()}" added successfully!`);
    } else {
      message.error('Class name already exists or is empty');
    }
  };

  const handleStageClick = (e) => {
    if (e.target === e.target.getStage()) {
      setSelectedAnnotation(null);
      const transformer = transformerRef.current;
      if (transformer) {
        transformer.nodes([]);
        transformer.getLayer().batchDraw();
      }
    }
  };

  if (loading) {
    return (
      <Layout style={{ minHeight: '100vh' }}>
        <Content style={{ display: 'flex', justifyContent: 'center', alignItems: 'center' }}>
          <div>Loading image...</div>
        </Content>
      </Layout>
    );
  }

  return (
    <Layout style={{ minHeight: '100vh' }}>
      {/* Left Sidebar */}
      <Sider width={300} style={{ background: '#fff', borderRight: '1px solid #f0f0f0' }}>
        <div style={{ padding: '16px' }}>
          <Button 
            icon={<ArrowLeftOutlined />} 
            onClick={() => navigate(`/annotate-progress/${datasetId}`)}
            style={{ marginBottom: '16px' }}
          >
            Back to Progress
          </Button>
          
          <Tabs defaultActiveKey="classes">
            <TabPane tab="Classes" key="classes">
              <div style={{ marginBottom: '16px' }}>
                <Button 
                  type="dashed" 
                  icon={<PlusOutlined />} 
                  block
                  onClick={() => setNewClassModalVisible(true)}
                >
                  Add New Class
                </Button>
              </div>
              
              <List
                dataSource={classes}
                renderItem={(className) => (
                  <List.Item
                    style={{
                      padding: '8px 0',
                      cursor: 'pointer',
                      backgroundColor: selectedClass === className ? '#e6f7ff' : 'transparent',
                      borderRadius: '4px',
                      paddingLeft: '8px'
                    }}
                    onClick={() => setSelectedClass(className)}
                  >
                    <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                      <div 
                        style={{
                          width: '16px',
                          height: '16px',
                          backgroundColor: getClassColor(className),
                          borderRadius: '2px'
                        }}
                      />
                      <Text strong={selectedClass === className}>{className}</Text>
                    </div>
                  </List.Item>
                )}
              />
            </TabPane>
            
            <TabPane tab="History" key="history">
              <div style={{ textAlign: 'center', padding: '20px' }}>
                <Text type="secondary">
                  {annotations.length} annotation{annotations.length !== 1 ? 's' : ''}
                </Text>
                <Divider />
                <Space direction="vertical" style={{ width: '100%' }}>
                  <Button 
                    icon={<UndoOutlined />} 
                    disabled={historyStep <= 0}
                    onClick={undo}
                    block
                  >
                    Undo
                  </Button>
                  <Button 
                    icon={<RedoOutlined />} 
                    disabled={historyStep >= history.length - 1}
                    onClick={redo}
                    block
                  >
                    Redo
                  </Button>
                </Space>
              </div>
            </TabPane>
            
            <TabPane tab="Comments" key="comments">
              <div style={{ textAlign: 'center', padding: '20px' }}>
                <Text type="secondary">Comments feature coming soon...</Text>
              </div>
            </TabPane>
          </Tabs>
        </div>
      </Sider>

      {/* Main Content */}
      <Layout>
        <Content style={{ background: '#f5f5f5' }}>
          {/* Top Toolbar */}
          <div style={{ 
            background: '#fff', 
            padding: '12px 16px', 
            borderBottom: '1px solid #f0f0f0',
            display: 'flex',
            justifyContent: 'space-between',
            alignItems: 'center'
          }}>
            <div>
              <Title level={4} style={{ margin: 0 }}>
                Manual Annotation - {image?.filename}
              </Title>
              <Text type="secondary">
                Selected Class: <Tag color={getClassColor(selectedClass)}>{selectedClass}</Tag>
              </Text>
            </div>
            
            <Space>
              <Button 
                type={tool === 'select' ? 'primary' : 'default'}
                icon={<SelectOutlined />}
                onClick={() => setTool('select')}
              >
                Select
              </Button>
              <Button 
                type={tool === 'draw' ? 'primary' : 'default'}
                icon={<BorderOutlined />}
                onClick={() => setTool('draw')}
              >
                Draw
              </Button>
              <Divider type="vertical" />
              <Button 
                icon={<ZoomInOutlined />}
                onClick={handleZoomIn}
                disabled={zoom >= 5}
              />
              <Button 
                icon={<ZoomOutOutlined />}
                onClick={handleZoomOut}
                disabled={zoom <= 0.1}
              />
              <Text style={{ minWidth: '60px', textAlign: 'center' }}>
                {Math.round(zoom * 100)}%
              </Text>
              <Divider type="vertical" />
              <Button 
                icon={<DeleteOutlined />}
                onClick={deleteSelectedAnnotation}
                disabled={!selectedAnnotation}
                danger
              />
              <Button 
                icon={<ReloadOutlined />}
                onClick={resetAnnotations}
                disabled={annotations.length === 0}
              />
              <Divider type="vertical" />
              <Button 
                type="primary"
                icon={<SaveOutlined />}
                onClick={saveAnnotations}
                loading={saving}
              >
                Save
              </Button>
            </Space>
          </div>

          {/* Canvas Area */}
          <div style={{ 
            height: 'calc(100vh - 120px)', 
            overflow: 'hidden',
            background: '#f0f0f0'
          }}>
            {imageObj && (
              <Stage
                ref={stageRef}
                width={window.innerWidth - 300}
                height={window.innerHeight - 120}
                scaleX={zoom}
                scaleY={zoom}
                x={stagePos.x}
                y={stagePos.y}
                onMouseDown={handleMouseDown}
                onMousemove={handleMouseMove}
                onMouseup={handleMouseUp}
                onWheel={handleWheel}
                onClick={handleStageClick}
                draggable={tool === 'select'}
              >
                <Layer>
                  <KonvaImage
                    image={imageObj}
                    width={imageObj.width}
                    height={imageObj.height}
                  />
                  
                  {annotations.map((annotation) => (
                    <Rect
                      key={annotation.id}
                      id={annotation.id}
                      x={annotation.x}
                      y={annotation.y}
                      width={annotation.width}
                      height={annotation.height}
                      stroke={annotation.color}
                      strokeWidth={2}
                      fill="transparent"
                      onClick={() => handleAnnotationClick(annotation)}
                      onTransformEnd={handleTransformEnd}
                      draggable={tool === 'select'}
                    />
                  ))}
                  
                  <Transformer
                    ref={transformerRef}
                    boundBoxFunc={(oldBox, newBox) => {
                      if (newBox.width < 5 || newBox.height < 5) {
                        return oldBox;
                      }
                      return newBox;
                    }}
                  />
                </Layer>
              </Stage>
            )}
          </div>
        </Content>
      </Layout>

      {/* Add New Class Modal */}
      <Modal
        title="Add New Class"
        open={newClassModalVisible}
        onOk={addNewClass}
        onCancel={() => {
          setNewClassModalVisible(false);
          setNewClassName('');
        }}
        okText="Add Class"
      >
        <Form layout="vertical">
          <Form.Item label="Class Name">
            <Input
              value={newClassName}
              onChange={(e) => setNewClassName(e.target.value)}
              placeholder="Enter class name"
              onPressEnter={addNewClass}
            />
          </Form.Item>
        </Form>
      </Modal>
    </Layout>
  );
};

export default AnnotateManual;